# Local database configuration example
driverClassName=com.mysql.cj.jdbc.Driver
url=jdbc:mysql://127.0.0.1:3306/ck_news?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
username=your_local_db_user
password=your_local_db_password
initialSize=5
maxActive=10
maxWait=1000

# Local runtime paths example
upload.path=/absolute/path/to/project/.runtime/uploads
log.path=/absolute/path/to/project/.runtime/logs

# JWT configuration example
jwt.secret=replace-with-your-own-secret-key-at-least-32-bytes
jwt.expireMillis=604800000
