        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ck.it.mapper.NewsUserMapper">

    <resultMap id="BaseResultMap" type="com.ck.it.pojo.NewsUser">
            <id property="uid" column="uid" />
